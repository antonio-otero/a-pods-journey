[mysqld]
# Juego de caracteres — utf8mb4 soporta emojis y caracteres especiales
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci
 
# Rendimiento
innodb_buffer_pool_size     = 256M
innodb_log_file_size        = 64M
max_connections             = 100
query_cache_type            = 0
 
# Seguridad
bind-address                = 0.0.0.0
local_infile                = 0
skip-symbolic-links
 
[client]
default-character-set = utf8mb4
